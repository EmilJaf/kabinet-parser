# --- App secrets (DEV only — prod reads these from ./secrets/) ---
# Generate:
#   FERNET_KEY: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
#   SECRET_KEY: python -c "import secrets;print(secrets.token_urlsafe(48))"
FERNET_KEY=
SECRET_KEY=

# --- Postgres (used by docker-compose) ---
POSTGRES_DB=unec
POSTGRES_USER=unec
POSTGRES_PASSWORD=unec

# --- CORS / origins ---
# Dev: separate Vite + API origins. Prod: set to https://<your-domain>.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Personal UNEC creds (only for the dev CLI; the multi-user app stores
# creds per user in the DB) ---
UNEC_USERNAME=
UNEC_PASSWORD=

# --- Service URLs (optional overrides) ---
# Defaults below assume docker-compose with postgres on host port 5433, redis on 6380
# (5432/6379 are skipped to avoid clashing with locally-installed services).
# DATABASE_URL=postgresql+asyncpg://unec:unec@localhost:5433/unec
# REDIS_URL=redis://localhost:6380/0

# --- Web Push (PWA notifications) ---
# Public VAPID key — sent to the browser, not secret. Generate with:
#   docker compose exec api unec admin gen-vapid
# Private key goes into secrets/vapid_private (prod) or VAPID_PRIVATE_KEY (dev).
VAPID_PUBLIC_KEY=
# Where push services contact you about delivery issues; mailto: prefix required.
VAPID_SUBJECT=mailto:admin@example.com

# --- PROD only (used by docker-compose.prod.yml + Caddy) ---
# APP_DOMAIN=kabinet.example.com
# ACME_EMAIL=you@example.com
